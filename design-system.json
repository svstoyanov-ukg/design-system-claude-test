  "spacing": {
    "0": "0px",
    "0.5": "2px",
    "1": "4px",
    "1.5": "6px",
    "2": "8px",
    "2.5": "10px",
    "3": "12px",
    "4": "16px",
    "5": "20px",
    "6": "24px",
    "7": "28px",
    "8": "32px",
    "10": "40px",
    "12": "48px",
    "16": "64px",
    "18": "72px",
    "description": "8px base grid. Primary rhythm: 4, 8, 16, 24, 32, 48px"
  },

  "borderRadius": {
    "none": "0px",
    "sm": "4px",
    "md": "8px",
    "lg": "10px",
    "xl": "12px",
    "2xl": "16px",
    "3xl": "20px",
    "pill": "50px",
    "extra": "48px",
    "full": "9999px",
    "description": "Cards use 2xl (16px). Buttons use pill (50px). Chat bubbles: 16px 4px 16px 16px. Avatar/icon buttons: full."
  },

  "shadow": {
    "none": "none",
    "description": "Elevation is communicated via background color contrast (white on gray) rather than drop shadows."
  },

  "animation": {
    "fadeIn": {
      "keyframes": "fade-in 1s ease forwards",
      "from": { "opacity": 0, "transform": "translateY(-10px)" },
      "to": { "opacity": 1, "transform": "none" }
    },
    "fadeUp": {
      "keyframes": "fade-up 1s ease forwards",
      "from": { "opacity": 0, "transform": "translateY(20px)" },
      "to": { "opacity": 1, "transform": "none" }
    },
    "shimmer": {
      "keyframes": "shimmer 8s infinite",
      "description": "Loading skeleton shimmer"
    },
    "marquee": {
      "keyframes": "marquee var(--duration) infinite linear",
      "description": "Horizontal ticker / carousel strip"
    },
    "marqueeVertical": {
      "keyframes": "marquee-vertical var(--duration) linear infinite",
      "description": "Vertical ticker"
    },
    "accordionDown": {
      "keyframes": "accordion-down 0.2s ease-out",
      "description": "Radix accordion expand"
    },
    "accordionUp": {
      "keyframes": "accordion-up 0.2s ease-out",
      "description": "Radix accordion collapse"
    }
  },

  "layout": {
    "maxWidth": "1704px",
    "contentMaxWidth": "960px",
    "gridTemplate": "68fr 31fr",
    "description": "Main viewport is 1704px. Two-column layout: 68% content + 31% AI panel. Content area centered to 960px max."
  },

  "components": {
    "topNav": {
      "description": "Application top navigation bar",
      "height": "64px",
      "background": "#FFFFFF",
      "padding": "16px",
      "elements": {
        "hamburgerMenu": {
          "type": "IconButton",
          "size": "40px",
          "borderRadius": "50px",
          "icon": "icon.svg"
        },
        "divider": {
          "type": "VerticalLine",
          "color": "rgba(0,0,0,0.10)",
          "width": "1px"
        },
        "logo": {
          "type": "Image",
          "src": "ukg-logo.svg",
          "width": "61px",
          "height": "24px"
        },
        "notificationIcon": {
          "type": "IconButton",
          "size": "40px",
          "borderRadius": "50px",
          "icon": "icon-7.svg"
        },
        "profileIcon": {
          "type": "IconButton",
          "size": "40px",
          "borderRadius": "50px",
          "icon": "icon-1.svg"
        }
      }
    },

    "pageHeader": {
      "description": "Page title block beneath top nav",
      "background": "#FFFFFF",
      "padding": "16px 152px",
      "maxContentWidth": "960px",
      "elements": {
        "title": {
          "typography": "displayMd",
          "color": "text.highEmphasisOnLight"
        },
        "subheading": {
          "typography": "headingSm",
          "color": "rgba(0,0,0,0.60)"
        },
        "divider": {
          "type": "HorizontalLine",
          "color": "rgba(0,0,0,0.10)",
          "marginTop": "16px"
        }
      }
    },

    "enrollmentBannerCard": {
      "description": "Open enrollment call-to-action card",
      "background": "#E2F8F6",
      "borderRadius": "2xl (16px)",
      "border": "none",
      "shadow": "none",
      "height": "225px",
      "layout": "two-column grid (1fr 260px)",
      "backgroundImages": ["background.svg", "card-pattern.svg"],
      "leftColumn": {
        "padding": "24px 24px 18px",
        "heading": { "typography": "headingLg", "color": "text.highEmphasisOnLight" },
        "body": { "typography": "copyMd", "color": "text.highEmphasisOnLight" },
        "cta": {
          "type": "GhostButton",
          "color": "action.active",
          "typography": "buttonMdMonochrome",
          "borderRadius": "50px"
        }
      },
      "rightColumn": {
        "padding": "24px",
        "icon": {
          "container": { "size": "48px", "borderRadius": "10.29px", "background": "rgba(48, 206, 187, 0.45)" },
          "src": "calendar.svg",
          "size": "20.57px"
        },
        "dateDisplay": { "typography": "displayMd", "color": "rgba(0,0,0,0.87)" },
        "daysLeft": { "typography": "headingVolteSemiboldS", "color": "rgba(0,0,0,0.45)" },
        "statusDot": {
          "size": "12.75px",
          "borderRadius": "full",
          "color": "badge.charcoal",
          "label": { "typography": "dataSmMid", "color": "rgba(0,0,0,0.60)" }
        }
      }
    },

    "quickLinkCard": {
      "description": "Horizontal navigation card with image on left",
      "background": "#FFFFFF",
      "border": "1px solid rgba(0,0,0,0.15)",
      "borderRadius": "2xl (16px)",
      "layout": "row, image left + text right",
      "imagePosition": "left/leading",
      "textStyle": "dataSmMid",
      "height": "56px",
      "states": {
        "hover": "cursor-pointer ring or shadow (default browser)",
        "focus": "focus-visible ring 2px action.focusBorderOnLight"
      }
    },

    "planRow": {
      "description": "Single benefit plan row inside 'Your family's plans' card",
      "background": "#FFFFFF",
      "padding": "24px",
      "layout": "row, space-between, items-center",
      "separator": "1px rgba(0,0,0,0.10) — mx-6",
      "leftBlock": {
        "planTitle": { "fontSize": "18px", "fontWeight": 600, "fontFamily": "DM Sans", "lineHeight": "22px", "letterSpacing": "-0.60px" },
        "providerLogo": "PNG image",
        "planName": { "typography": "dataMdHigh" },
        "detailLabel": { "typography": "dataSmMid" },
        "detailValue": { "typography": "dataSmHigh" }
      },
      "rightBlock": {
        "youPayLabel": { "typography": "dataSmLow", "color": "rgba(0,0,0,0.60)", "align": "right" },
        "amount": { "typography": "displayXs", "color": "text.highEmphasisOnLight", "align": "right" },
        "perPaycheckLabel": { "typography": "dataSmLow", "color": "rgba(0,0,0,0.60)", "align": "right" },
        "changeLink": { "typography": "copyMd", "color": "action.textActionEnabled", "align": "right" }
      }
    },

    "companySavingsWidget": {
      "description": "Sidebar widget — company message card",
      "background": "transparent",
      "borderRadius": "2xl (16px)",
      "elements": {
        "eyebrow": { "typography": "copyItalic", "color": "rgba(0,0,0,0.60)" },
        "title": { "typography": "headingBoxHeading", "color": "text.highEmphasisOnLight" },
        "body": { "typography": "copyMd", "color": "text.highEmphasisOnLight" }
      }
    },

    "tab": {
      "description": "Navigation tab item",
      "height": "46px",
      "minWidth": "113px",
      "padding": "14px 16px",
      "typography": "buttonMdMonochrome",
      "states": {
        "selected": {
          "selectedIndicator": {
            "height": "4px",
            "borderRadius": "2px",
            "background": "action.enabled",
            "position": "bottom-0"
          }
        },
        "unselected": {
          "selectedIndicator": "hidden"
        },
        "focused": {
          "focusRing": "2px inset focus.borderOnLight"
        }
      },
      "badge": {
        "background": "surface.light",
        "borderRadius": "full",
        "minWidth": "19px",
        "height": "16px",
        "countTypography": "dataXsCondensedHigh"
      }
    },

    "aiAssistantPanel": {
      "description": "Right-rail Bryte AI assistant panel",
      "width": "31fr (approximately 530px at 1704px viewport)",
      "minHeight": "980px",
      "background": "linear-gradient(0deg, rgba(245,235,220,0.20), rgba(245,235,220,0.20)), #FFFFFF",
      "borderLeft": "1px solid #EBDCCD",
      "header": {
        "height": "52px",
        "padding": "12px 24px",
        "elements": {
          "menuButton": { "type": "IconButton", "icon": "icon-8.svg", "borderRadius": "full", "padding": "8px" },
          "bryteLogo": { "src": "bryte-logo.svg", "size": "24px" },
          "panelTitle": { "typography": "navigationHeading", "color": "text.highEmphasisOnLight" },
          "fullscreenButton": { "type": "IconButton", "icon": "fullscreen.svg", "borderRadius": "full", "padding": "8px" }
        }
      },
      "chatArea": {
        "padding": "0 24px",
        "scrollable": true
      },
      "userBubble": {
        "maxWidth": "100%",
        "background": "linear-gradient(0deg, rgba(245,235,220,0.55), rgba(245,235,220,0.55)), #FFFFFF",
        "borderRadius": "16px 4px 16px 16px",
        "padding": "12px 20px",
        "typography": "copyMd",
        "color": "rgba(0,0,0,0.87)",
        "align": "flex-end"
      },
      "assistantMessage": {
        "typography": "copyMd",
        "color": "text.highEmphasisOnLight",
        "align": "flex-start",
        "ctaButton": {
          "background": "action.midEnabled",
          "borderRadius": "50px",
          "padding": "6px 16px",
          "color": "#0A1E18",
          "typography": "buttonMdMonochrome"
        }
      },
      "inputBar": {
        "background": "#FFFFFF",
        "border": "1px solid #EBDCCD",
        "borderRadius": "12px",
        "padding": "6px 8px 6px 20px",
        "margin": "0 24px",
        "placeholder": {
          "text": "Search or ask Bryte",
          "typography": "formSmEnabled",
          "color": "rgba(0,0,0,0.60)"
        },
        "actions": [
          { "icon": "icon-5.svg", "label": "Attachments", "type": "IconButton" },
          { "icon": "microphone.svg", "label": "Microphone", "type": "IconButton" }
        ]
      }
    },

    "button": {
      "variants": {
        "ghost": {
          "background": "transparent",
          "color": "inherited from context",
          "borderRadius": "50px",
          "hover": "bg-transparent (no bg change)",
          "padding": "6px 8px"
        },
        "ctaPill": {
          "background": "action.midEnabled (rgba(120,207,184,0.20))",
          "color": "#0A1E18",
          "borderRadius": "50px",
          "padding": "6px 16px",
          "typography": "buttonMdMonochrome"
        },
        "textLink": {
          "background": "transparent",
          "color": "action.textActionEnabled",
          "typography": "copyMd"
        }
      }
    }
  },

  "assets": {
    "icons": [
      { "name": "hamburger-menu", "file": "icon.svg" },
      { "name": "notifications", "file": "icon-7.svg" },
      { "name": "profile", "file": "icon-1.svg" },
      { "name": "download", "file": "icon-3.svg" },
      { "name": "attachment", "file": "icon-5.svg" },
